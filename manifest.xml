<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>95c11482-1b19-4b93-ab9a-1c6d8fd5d8de</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Common Approach To Impact Measurement</ProviderName>
  <DefaultLocale>en-CA</DefaultLocale>
  <DisplayName DefaultValue="Common Impact Data Standard">
    <Override Locale="en-US" Value="Common Impact Data Standard" />
    <Override Locale="en-CA" Value="Common Impact Data Standard" />
    <Override Locale="fr-FR" Value="Norme de données d'impact commun" />
    <Override Locale="fr-CA" Value="Norme de données d'impact commun" />
  </DisplayName>
  <Description DefaultValue="A utility to share and aggregate impact data from multiple softwares.">
    <Override Locale="en-US"
      Value="A utility to share and aggregate impact data from multiple softwares." />
    <Override Locale="en-CA"
      Value="A utility to share and aggregate impact data from multiple softwares." />
    <Override Locale="fr-FR"
      Value="Un utilitaire pour partager et agréger les données d'impact de plusieurs logiciels." />
    <Override Locale="fr-CA"
      Value="Un utilitaire pour partager et agréger les données d'impact de plusieurs logiciels." />
  </Description>
  <IconUrl DefaultValue="https://localhost:3000/assets/logo-32x32.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/logo-64x64.png" />
  <SupportUrl DefaultValue="https://www.commonapproach.org/" />
  <AppDomains>
    <AppDomain>https://ontology.commonapproach.org</AppDomain>
    <AppDomain>https://codelist.commonapproach.org</AppDomain>
    <AppDomain>https://www.commonapproach.org</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook" />
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="ExcelApi" MinVersion="1.1" />
      <Set Name="OpenBrowserWindowApi" MinVersion="1.1" />
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/taskpane.html" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
    xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl" />
          </GetStarted>
          <FunctionFile resid="Taskpane.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label" />
                <Icon>
                  <bt:Image size="16" resid="Logo.16x16" />
                  <bt:Image size="32" resid="Logo.32x32" />
                  <bt:Image size="80" resid="Logo.80x80" />
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Logo.16x16" />
                    <bt:Image size="32" resid="Logo.32x32" />
                    <bt:Image size="80" resid="Logo.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Logo.16x16" DefaultValue="https://localhost:3000/assets/logo-16x16.png" />
        <bt:Image id="Logo.32x32" DefaultValue="https://localhost:3000/assets/logo-32x32.png" />
        <bt:Image id="Logo.80x80" DefaultValue="https://localhost:3000/assets/logo-80x80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl"
          DefaultValue="https://go.microsoft.com/fwlink/?LinkId=276812" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://localhost:3000/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title"
          DefaultValue="Get started with Common Approach to Impact Measurement add-in!">
          <bt:Override Locale="fr-FR"
            Value="Commencez à utiliser l'add-in Common Approach to Impact Measurement !" />
          <bt:Override Locale="fr-CA"
            Value="Commencez à utiliser l'add-in Common Approach to Impact Measurement !" />
        </bt:String>
        <bt:String id="CommandsGroup.Label" DefaultValue="Commands Group">
          <bt:Override Locale="fr-FR" Value="Groupe de commandes" />
          <bt:Override Locale="fr-CA" Value="Groupe de commandes" />
        </bt:String>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Common Approach">
          <bt:Override Locale="fr-FR" Value="Common Approach" />
          <bt:Override Locale="fr-CA" Value="Common Approach" />
        </bt:String>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description"
          DefaultValue="The Common Approach to Impact Measurement add-in loaded succesfully. Go to the HOME tab and click the 'Common Approach' button to get started.">
          <bt:Override Locale="fr-FR"
            Value="L'add-in Common Approach to Impact Measurement a été chargé avec succès. Accédez à l'onglet ACCUEIL et cliquez sur le bouton 'Common Approach' pour commencer." />
          <bt:Override Locale="fr-CA"
            Value="L'add-in Common Approach to Impact Measurement a été chargé avec succès. Accédez à l'onglet ACCUEIL et cliquez sur le bouton 'Common Approach' pour commencer." />
        </bt:String>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Click to Open the Taskpane">
          <bt:Override Locale="fr-FR" Value="Cliquez pour ouvrir le volet de tâches" />
          <bt:Override Locale="fr-CA" Value="Cliquez pour ouvrir le volet de tâches" />
        </bt:String>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>